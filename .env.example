OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# Local server guardrails for /api/agent.
OPENAI_DAILY_SPEND_LIMIT_USD=5
OPENAI_AGENT_MAX_REQUEST_USD=0.35
OPENAI_AGENT_RATE_LIMIT_PER_MINUTE=6
OPENAI_AGENT_MAX_OUTPUT_TOKENS=900
OPENAI_AGENT_USAGE_FILE=.quest-agent-usage.json

# Pricing defaults are conservative estimates used for local spend accounting.
# Update these if your selected model uses different pricing.
OPENAI_INPUT_COST_PER_1M_USD=1.25
OPENAI_OUTPUT_COST_PER_1M_USD=10

# Optional: point road-route geometry at your own OSRM service for heavier usage.
OSRM_BASE_URL=https://router.project-osrm.org

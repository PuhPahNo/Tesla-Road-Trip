OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# Local server guardrails for /api/agent.
OPENAI_DAILY_SPEND_LIMIT_USD=5
OPENAI_AGENT_MAX_REQUEST_USD=0.35
OPENAI_AGENT_RATE_LIMIT_PER_MINUTE=6
OPENAI_AGENT_MAX_OUTPUT_TOKENS=900
OPENAI_AGENT_USAGE_FILE=.quest-agent-usage.json

# Pricing defaults are conservative estimates used for local spend accounting.
# Update these if your selected model uses different pricing.
OPENAI_INPUT_COST_PER_1M_USD=1.25
OPENAI_OUTPUT_COST_PER_1M_USD=10

# --- Road-accurate distances + true (speed-limit) drive times — OPTIONAL ---
# Recommended: a free OpenRouteService key (https://openrouteservice.org) gives
# real road distances AND real drive times. Set it LOCALLY for accurate planning;
# leave it UNSET on a hosted/public deploy to stay within the free request quota
# (the app falls back to fast estimates automatically). See docs/OSRM.md.
# ORS_API_KEY=your-free-ors-key

# Alternatively, a self-hosted OSRM engine (heavier — see docs/OSRM.md). The
# public demo can't handle long national routes; run a local one:
#   bash scripts/osrm-setup.sh   ->   OSRM_BASE_URL=http://localhost:5001
OSRM_BASE_URL=https://router.project-osrm.org

# First launch seeds username "anthony" with temporary password "admin123".
# Protected planner, community, and admin actions remain locked until it is changed.

# Optional local/production database override. Render defaults to /data.
# CHARGE_QUEST_DB_PATH=/data/charge-quest.sqlite
